#: .\venv\Lib\site-packages\django\views\csrf.py:29
msgid "Forbidden"
msgstr "Taqiqlangan"

#: .\venv\Lib\site-packages\django\views\csrf.py:30
msgid "CSRF verification failed. Request aborted."
msgstr "CSRF tekshiruvi muvaffaqiyatsiz tugadi. So'rov bekor qilindi."

#: .\venv\Lib\site-packages\django\views\csrf.py:34
msgid ""
"You are seeing this message because this HTTPS site requires a \u201cReferer "
"header\u201d to be sent by your web browser, but none was sent. This header is "
"required for security reasons, to ensure that your browser is not being "
"hijacked by third parties."
msgstr ""
"Siz bu xabarni ko'rmoqdasiz, chunki bu HTTPS sayt brauzeringizdan \"Referer "
"sarlavhasi\" yuborilishini talab qiladi, lekin hech qanday yuborilmadi. Bu sarlavha "
"xavfsizlik sabablari uchun, brauzeringiz uchinchi shaxslar tomonidan egallanmasligini "
"ta'minlash uchun talab etiladi."

#: .\venv\Lib\site-packages\django\views\csrf.py:40
msgid ""
"If you have configured your browser to disable \u201cReferer\u201d headers, please re-"
"enable them, at least for this site, or for HTTPS connections, or for \u201csame-"
"origin\u201d requests."
msgstr ""
"Agar brauzeringizda \"Referer\" sarlavhalarini o'chirib qo'ygan bo'lsangiz, iltimos "
"kamida ushbu sayt uchun yoki HTTPS ulanishlari uchun yoki \"bir xil manba\" "
"so'rovlari uchun ularni qayta yoqing."

#: .\venv\Lib\site-packages\django\views\csrf.py:45
msgid ""
"If you are using the <meta name=\"referrer\" content=\"no-referrer\"> tag or "
"including the \u201cReferrer-Policy: no-referrer\u201d header, please remove them. The "
"CSRF protection requires the \u201cReferer\u201d header to do strict referer checking. "
"If you're concerned about privacy, use alternatives like <a "
"rel=\"noreferrer\" \u2026> for links to third-party sites."
msgstr ""
"Agar <meta name=\"referrer\" content=\"no-referrer\"> tegidan yoki \"Referrer-Policy: "
"no-referrer\" sarlavhasidan foydalanayotgan bo'lsangiz, iltimos ularni olib tashlang. "
"CSRF himoyasi qat'iy referer tekshiruvi uchun \"Referer\" sarlavhasini talab qiladi. "
"Maxfiylik haqida qayg'ursangiz, uchinchi tomon saytlariga havolalar uchun "
"<a rel=\"noreferrer\" …> kabi muqobillardan foydalaning."

#: .\venv\Lib\site-packages\django\views\csrf.py:54
msgid ""
"You are seeing this message because this site requires a CSRF cookie when "
"submitting forms. This cookie is required for security reasons, to ensure "
"that your browser is not being hijacked by third parties."
msgstr ""
"Siz bu xabarni ko'rmoqdasiz, chunki bu sayt formalarni yuborishda CSRF kukilarini "
"talab qiladi. Bu kukil xavfsizlik sabablari uchun, brauzeringiz uchinchi shaxslar "
"tomonidan egallanmasligini ta'minlash uchun talab etiladi."

#: .\venv\Lib\site-packages\django\views\csrf.py:60
msgid ""
"If you have configured your browser to disable cookies, please re-enable "
"them, at least for this site, or for \u201csame-origin\u201d requests."
msgstr ""
"Agar brauzeringizda kukilarni o'chirib qo'ygan bo'lsangiz, iltimos kamida ushbu "
"sayt uchun yoki \"bir xil manba\" so'rovlari uchun ularni qayta yoqing."

#: .\venv\Lib\site-packages\django\views\csrf.py:66
msgid "More information is available with DEBUG=True."
msgstr "Qo'shimcha ma'lumot DEBUG=True bilan mavjud."

